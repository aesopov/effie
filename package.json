    "@types/react-is": "^19.2.0",
    "@types/react-reconciler": "^0.33.0",
    "react": "^19.2.0",
    "rollup": "^4.60.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-is": "^19.0.0",
